{
  "name": "@arnilo/prism-web-tools",
  "version": "0.0.96",
  "description": "Optional bounded Brave, Exa, and Firecrawl web research tools for Prism.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./brave": {
      "types": "./dist/brave.d.ts",
      "default": "./dist/brave.js"
    },
    "./exa": {
      "types": "./dist/exa.d.ts",
      "default": "./dist/exa.js"
    },
    "./firecrawl": {
      "types": "./dist/firecrawl.d.ts",
      "default": "./dist/firecrawl.js"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/**/*.map",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/__tests__/web-tools.test.js",
    "test:live": "node --test dist/__tests__/live.test.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@arnilo/prism": "0.0.96"
  },
  "devDependencies": {
    "@arnilo/prism": "file:../.."
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashiqrniloy/prism.git",
    "directory": "packages/web-tools"
  },
  "bugs": {
    "url": "https://github.com/ashiqrniloy/prism/issues"
  },
  "homepage": "https://github.com/ashiqrniloy/prism/tree/main/packages/web-tools#readme",
  "keywords": [
    "prism",
    "web-search",
    "exa",
    "brave",
    "firecrawl"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
