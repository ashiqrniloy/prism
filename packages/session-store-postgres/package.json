{
  "name": "@arnilo/prism-session-store-postgres",
  "version": "0.0.5",
  "description": "Optional PostgreSQL SessionStore, RunLedger, and ProductionPersistenceStore adapter for Prism.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/**/*.map",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/__tests__/*.test.js",
    "test:postgres": "node --test dist/__tests__/*.test.js dist/__tests__/*.integration.test.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "pg": "^8.22.0"
  },
  "peerDependencies": {
    "@arnilo/prism": "0.0.5"
  },
  "devDependencies": {
    "@arnilo/prism": "file:../..",
    "@types/pg": "^8.11.11"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashiqrniloy/prism.git",
    "directory": "packages/session-store-postgres"
  },
  "bugs": {
    "url": "https://github.com/ashiqrniloy/prism/issues"
  },
  "homepage": "https://github.com/ashiqrniloy/prism/tree/main/packages/session-store-postgres#readme",
  "keywords": [
    "prism",
    "postgres",
    "postgresql",
    "session-store",
    "persistence",
    "run-ledger",
    "agent"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
