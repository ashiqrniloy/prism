{
  "name": "@arnilo/prism-browser",
  "version": "0.0.96",
  "description": "Optional Prism browser tools over a host-supplied Playwright Browser: open, snapshot, act, and close with run-owned contexts, egress policy, and upload/download/screenshot quarantine.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/**/*.map",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/__tests__/*.test.js",
    "test:live": "node --test dist/__tests__/live.test.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@arnilo/prism": "0.0.96",
    "playwright-core": "1.61.0"
  },
  "peerDependenciesMeta": {
    "playwright-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arnilo/prism": "file:../..",
    "@arnilo/prism-evals": "file:../evals",
    "playwright-core": "1.61.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashiqrniloy/prism.git",
    "directory": "packages/browser"
  },
  "bugs": {
    "url": "https://github.com/ashiqrniloy/prism/issues"
  },
  "homepage": "https://github.com/ashiqrniloy/prism/tree/main/packages/browser#readme",
  "keywords": [
    "prism",
    "browser",
    "playwright",
    "tools",
    "agent",
    "llm"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
