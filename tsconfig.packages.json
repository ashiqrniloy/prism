{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "prism": ["./dist/index.d.ts"],
      "prism/testing/provider-conformance": ["./dist/testing/provider-conformance.d.ts"],
      "prism/*": ["./dist/*"]
    }
  }
}
