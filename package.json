{
  "name": "@arnilo/prism",
  "version": "0.0.8",
  "description": "Agent harness for AI providers, agents, sessions, and tools.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers/openai-compatible": {
      "types": "./dist/providers/openai-compatible.d.ts",
      "default": "./dist/providers/openai-compatible.js"
    },
    "./providers/transport": {
      "types": "./dist/providers/transport.d.ts",
      "default": "./dist/providers/transport.js"
    },
    "./providers/openai": {
      "types": "./dist/providers/openai-primitives.d.ts",
      "default": "./dist/providers/openai-primitives.js"
    },
    "./providers/media": {
      "types": "./dist/providers/media.d.ts",
      "default": "./dist/providers/media.js"
    },
    "./testing/provider-conformance": {
      "types": "./dist/testing/provider-conformance.d.ts",
      "default": "./dist/testing/provider-conformance.js"
    },
    "./testing/session-store-conformance": {
      "types": "./dist/testing/session-store-conformance.d.ts",
      "default": "./dist/testing/session-store-conformance.js"
    },
    "./testing/compaction-conformance": {
      "types": "./dist/testing/compaction-conformance.d.ts",
      "default": "./dist/testing/compaction-conformance.js"
    },
    "./testing/tool-conformance": {
      "types": "./dist/testing/tool-conformance.d.ts",
      "default": "./dist/testing/tool-conformance.js"
    },
    "./testing/extension-conformance": {
      "types": "./dist/testing/extension-conformance.d.ts",
      "default": "./dist/testing/extension-conformance.js"
    },
    "./testing/persistence-schema": {
      "types": "./dist/testing/persistence-schema.d.ts",
      "default": "./dist/testing/persistence-schema.js"
    },
    "./testing/run-ledger-conformance": {
      "types": "./dist/testing/run-ledger-conformance.d.ts",
      "default": "./dist/testing/run-ledger-conformance.js"
    },
    "./testing/feedback": {
      "types": "./dist/testing/feedback.d.ts",
      "default": "./dist/testing/feedback.js"
    },
    "./node/config": {
      "types": "./dist/node/config.d.ts",
      "default": "./dist/node/config.js"
    },
    "./node/settings": {
      "types": "./dist/node/settings.d.ts",
      "default": "./dist/node/settings.js"
    },
    "./node/trust": {
      "types": "./dist/node/trust.d.ts",
      "default": "./dist/node/trust.js"
    },
    "./node/session-store-jsonl": {
      "types": "./dist/node/session-store-jsonl.d.ts",
      "default": "./dist/node/session-store-jsonl.js"
    },
    "./node/contribution-discovery": {
      "types": "./dist/node/contribution-discovery.d.ts",
      "default": "./dist/node/contribution-discovery.js"
    },
    "./node/instruction-injectors": {
      "types": "./dist/node/instruction-injectors.d.ts",
      "default": "./dist/node/instruction-injectors.js"
    },
    "./node/system-prompts": {
      "types": "./dist/node/system-project-prompts.d.ts",
      "default": "./dist/node/system-project-prompts.js"
    },
    "./node/agent-definitions": {
      "types": "./dist/node/agent-definitions.d.ts",
      "default": "./dist/node/agent-definitions.js"
    }
  },
  "bin": {
    "prism": "dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/**/*.map",
    "docs",
    "templates",
    "CHANGELOG.md"
  ],
  "workspaces": [
    "packages/provider-*",
    "packages/compaction-*",
    "packages/observability-*",
    "packages/tool-validator-*",
    "packages/session-store-*",
    "packages/credentials-node",
    "packages/mcp",
    "packages/coding-agent",
    "packages/coding-security",
    "packages/workflows",
    "packages/evals",
    "packages/memory",
    "packages/rag",
    "packages/server",
    "packages/supervisor",
    "packages/web-tools",
    "packages/prism-*"
  ],
  "scripts": {
    "build:core": "tsc",
    "build": "npm run build:core && npm run build --workspaces --if-present",
    "typecheck": "npm run build && npm run typecheck --workspaces --if-present && tsc -p examples --noEmit",
    "test": "npm run build && node --test dist/__tests__/*.test.js && npm run test --workspaces --if-present",
    "pack:dry-run": "npm pack --dry-run && npm run pack:dry-run --workspaces --if-present",
    "test:postgres": "npm run test:postgres --workspace @arnilo/prism-session-store-postgres && npm run test:postgres --workspace @arnilo/prism-memory",
    "release:dry-run": "npm run sdk:ready",
    "release:check": "node scripts/release.mjs check",
    "release:publish": "node scripts/release.mjs publish",
    "sdk:ready": "npm run typecheck && npm test && npm run pack:dry-run"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashiqrniloy/prism.git"
  },
  "bugs": {
    "url": "https://github.com/ashiqrniloy/prism/issues"
  },
  "homepage": "https://github.com/ashiqrniloy/prism#readme",
  "keywords": [
    "prism",
    "agent",
    "llm",
    "ai",
    "framework",
    "chatbot"
  ],
  "sideEffects": [
    "dist/cli.js"
  ],
  "publishConfig": {
    "access": "public"
  }
}
